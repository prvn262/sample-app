<!DOCTYPE html>
<html>
  <head>
    <title><%= full_title(yield(:title)) %></title>
    <%# yield(:title) pulls the title you set in views via <% provide(:title, "Page") %> 
        <%# full_title is a helper in app/helpers/application_helper.rb %>

    <meta charset="utf-8">

    <%# UTF-8 encoding for full character support %>
    
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <%= csrf_meta_tags %>
    <%# Protects against CSRF attacks %>

    <%= csp_meta_tag %>
    <%# Adds Content Security Policy headers to block malicious scripts %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload", media: "all" %>
    <%# Loads app/assets/stylesheets/application.(css|scss) via Propshaft or Sprockets %>

    <%= javascript_importmap_tags %>
    <%# Loads JavaScript modules defined in config/importmap.rb and app/javascript/application.js %>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- PopperJS + Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"></script>
  </head>

  <body>
    <%= render "layouts/header" %>

    <div class="container text-left" style="margin: 15px;">
      <% flash.each do |message_type, message| %>
        <div class="alert alert-<%= message_type %>"><%= message %> </div>
      <% end %>
      <%= yield %>
      <%# Page-specific content gets injected here %>
      <% debug(params) if Rails.env.development? %>
    </div>

    <%= render "layouts/footer" %>
  </body>
</html>
